/* ==========================================
   LAPTOP BESAR
========================================== */

@media(max-width:1200px){

.container{
    width:92%;
}

.hero h1{
    font-size:60px;
}

section{
    padding:90px 0;
}

}


/* ==========================================
   TABLET LANDSCAPE
========================================== */

@media(max-width:992px){

.header{
    background:#111;
}

.nav{

    flex-wrap:wrap;

    height:auto;

    padding:20px 0;

}

nav{
    width:100%;
    margin-top:20px;
}

nav ul{

    justify-content:center;

    flex-wrap:wrap;

    gap:18px;

}

.btn-order{

    margin-top:20px;

}

.hero{

    height:90vh;

}

.hero h1{

    font-size:52px;

}

.hero p{

    font-size:20px;

}

.about-box{

    grid-template-columns:1fr;

    gap:50px;

}

.right h2{

    text-align:center;

}

.right{

    text-align:center;

}

.feature-box{

    grid-template-columns:repeat(2,1fr);

}

.gallery-grid{

    grid-template-columns:repeat(2,1fr);

}

.footer{

    grid-template-columns:repeat(2,1fr);

}

}


/* ==========================================
   TABLET
========================================== */

@media(max-width:768px){

.logo h2{

    font-size:18px;

}

.logo img{

    width:45px;

}

.hero{

    padding:0 20px;

}

.hero h1{

    font-size:42px;

    line-height:1.2;

}

.hero p{

    font-size:18px;

}

.hero-button{

    flex-direction:column;

    align-items:center;

}

.btn1,
.btn2{

    width:250px;

    text-align:center;

}

section h2{

    font-size:34px;

}

.card-area{

    grid-template-columns:1fr;

}

.feature-box{

    grid-template-columns:1fr;

}

.gallery-grid{

    grid-template-columns:1fr;

}

.gallery-grid img{

    height:240px;

}

.footer{

    grid-template-columns:1fr;

    text-align:center;

}

.social{

    justify-content:center;

}

.cta h2{

    font-size:36px;

}

.cta p{

    font-size:18px;

}

}


/* ==========================================
   MOBILE
========================================== */

@media(max-width:576px){

.container{

    width:94%;

}

.header{

    padding:5px 0;

}

.nav{

    flex-direction:column;

}

.logo{

    flex-direction:column;

}

.logo img{

    width:60px;

}

nav ul{

    flex-direction:column;

    align-items:center;

    gap:15px;

}

.btn-order{

    width:100%;

    text-align:center;

}

.hero{

    min-height:100vh;

}

.hero h1{

    font-size:34px;

}

.hero p{

    font-size:16px;

}

.btn1,
.btn2{

    width:100%;

}

.card{

    border-radius:15px;

}

.card img{

    height:220px;

}

.card h3{

    font-size:20px;

}

.card span{

    font-size:22px;

}

.left img{

    border-radius:15px;

}

.right p{

    font-size:15px;

}

.right ul li{

    font-size:15px;

}

.cta{

    padding:70px 20px;

}

.cta h2{

    font-size:30px;

}

.cta p{

    font-size:16px;

}

.cta a{

    width:100%;

    display:block;

}

.footer h3{

    font-size:24px;

}

.footer h4{

    font-size:18px;

}

.wa{

    width:60px;

    height:60px;

    right:18px;

    bottom:18px;

}

.wa img{

    width:30px;

}

.top{

    width:55px;

    height:55px;

    left:18px;

    bottom:18px;

}

}


/* ==========================================
   MOBILE KECIL
========================================== */

@media(max-width:400px){

.hero h1{

    font-size:28px;

}

.hero p{

    font-size:15px;

}

section{

    padding:70px 0;

}

section h2{

    font-size:28px;

}

.logo h2{

    font-size:16px;

}

.card h3{

    font-size:18px;

}

.card span{

    font-size:20px;

}

.footer{

    gap:30px;

}

}


/* ==========================================
   LAYAR BESAR (2K/4K)
========================================== */

@media(min-width:1600px){

.container{

    max-width:1450px;

}

.hero h1{

    font-size:90px;

}

.hero p{

    font-size:30px;

}

section h2{

    font-size:52px;

}

.card img{

    height:320px;

}

.gallery-grid img{

    height:320px;

}

}